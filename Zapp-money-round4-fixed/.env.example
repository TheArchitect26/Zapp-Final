# =============================================================
# Zapp Money — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# -----------------------------------------------
# BACKEND (Node.js / Express)
# -----------------------------------------------

# PostgreSQL connection string (from Supabase → Project Settings → Database)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase project URL
SUPABASE_URL=https://[project-ref].supabase.co

# Supabase service-role key — bypasses RLS — SERVER SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Frontend origin for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173

# Webhook signing secret (shared with your payment provider)
WEBHOOK_SECRET=whsec_...

# Optional: Python ML microservice URL
ML_API_URL=http://localhost:8000

# Governance limits (optional, has safe defaults)
GOV_MAX_DAILY_VOLUME=2000000
GOV_MAX_RISK_SCORE=0.75
GOV_MAX_LIQ_DRAIN=300000
MAX_DAILY_SYSTEM_MOVEMENT=1000000
MAX_PER_USER_MOVEMENT=100000
KILL_SWITCH_FRAUD_THRESHOLD=15
CONSENSUS_THRESHOLD=1000

# Node environment
NODE_ENV=development


# -----------------------------------------------
# FRONTEND (Vite)
# All VITE_ prefixed vars are embedded in the browser bundle — never put secrets here.
# -----------------------------------------------

# Supabase project URL (public)
VITE_SUPABASE_URL=https://[project-ref].supabase.co

# Supabase anon/publishable key (public — safe for browser)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Backend API base URL (used by store.ts for financial writes)
VITE_API_BASE_URL=http://localhost:3001


# -----------------------------------------------
# PYTHON MICROSERVICES (fraud_api.py, transfer_api.py)
# -----------------------------------------------

# Path to the trained fraud model (loaded at startup — not committed to git)
FRAUD_MODEL_PATH=/opt/models/fraud_model.pkl

# -----------------------------------------------
# PAYMENTS — MTN MoMo Open API
# Sandbox base URL: https://sandbox.momodeveloper.mtn.com
# Production base URL: https://proxy.momoapi.mtn.com
# -----------------------------------------------
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_TARGET_ENV=sandbox
MOMO_CALLBACK_HOST=https://your-backend.com

# Collections (charge user's MoMo wallet — top-up)
MOMO_COLLECTION_SUB_KEY=your-collection-subscription-key
MOMO_COLLECTION_API_USER=your-collection-api-user-uuid
MOMO_COLLECTION_API_KEY=your-collection-api-key

# Disbursements (pay out to MoMo wallet — withdrawal, deposit, refund)
MOMO_DISBURSEMENT_SUB_KEY=your-disbursement-subscription-key
MOMO_DISBURSEMENT_API_USER=a0a79b13-d801-4b27-9a2e-d428f0ef1727
MOMO_DISBURSEMENT_API_KEY=your-disbursement-api-key

# -----------------------------------------------
# PAYMENTS — Paystack
# -----------------------------------------------
PAYSTACK_SECRET_KEY=sk_test_...

# -----------------------------------------------
# EARN — Provider Webhook Secrets
# -----------------------------------------------
EARN_WEBHOOK_SECRET_POLLFISH=your-pollfish-secret
EARN_WEBHOOK_SECRET_ADGATE=your-adgate-secret
EARN_WEBHOOK_SECRET_TAPJOY=your-tapjoy-secret

# -----------------------------------------------
# PAYMENTS — Peach Payments
# -----------------------------------------------
PEACH_PAYMENTS_BASE_URL=https://testopenapi.peachpayments.com
PEACH_PAYMENTS_API_KEY=your-peach-api-key
PEACH_PAYMENTS_ENTITY_ID=your-peach-entity-id
# Shared secret for verifying Peach webhook signatures
PEACH_WEBHOOK_SECRET=your-peach-webhook-secret

# -----------------------------------------------
# KYC — Smile Identity
# -----------------------------------------------
SMILE_PARTNER_ID=your-smile-partner-id
SMILE_API_KEY=your-smile-api-key
SMILE_CALLBACK_URL=https://your-backend.com/api/v1/webhooks/smile

# -----------------------------------------------
# PUSH NOTIFICATIONS — Web Push / VAPID
# -----------------------------------------------
VAPID_EMAIL=mailto:notifications@zappmoney.co.za
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# -----------------------------------------------
# SERVER
# -----------------------------------------------
PORT=3000
BACKEND_URL=http://localhost:3000

# -----------------------------------------------
# BRAIN / CIRCUIT BREAKER (optional, has safe defaults)
# -----------------------------------------------
BRAIN_MODE=SHADOW
BRAIN_FAILURE_RATE_THRESHOLD=0.3
BRAIN_FRAUD_SPIKE_THRESHOLD=20

# -----------------------------------------------
# LIQUIDITY / TREASURY (optional, has safe defaults)
# -----------------------------------------------
MAX_POOL_DRAIN=200000
MIN_RESERVE=50000
CONFIDENCE_THRESHOLD=0.65

# -----------------------------------------------
# MESH ROUTING (optional, has safe defaults)
# -----------------------------------------------
MAX_ROUTE_COST=50000
MAX_ROUTE_LATENCY=5000

# -----------------------------------------------
# SETTLEMENT WORKER (optional, has safe defaults)
# -----------------------------------------------
SETTLEMENT_MAX_RETRIES=3
SETTLEMENT_POLL_INTERVAL_MS=5000
SETTLEMENT_WORKER_CONCURRENCY=4

# Alias for SUPABASE_SERVICE_ROLE_KEY (legacy — prefer SUPABASE_SERVICE_ROLE_KEY)
SUPABASE_SERVICE_KEY=
